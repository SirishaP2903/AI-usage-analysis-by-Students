      <aliases enabled='yes' />
      <column caption='AI Ethics Concern' datatype='string' name='[AI_Ethics_Concern]' role='dimension' type='nominal' />
      <column datatype='integer' name='[Age]' role='measure' type='quantitative' />
      <column caption='GPA Change' datatype='real' name='[Calculation_2174394257446178816]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[GPA_Post_AI] - [GPA_Baseline]' />
      </column>
      <column caption='GPA Change %' datatype='real' name='[Calculation_2174394257446412289]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_2174394257446178816]/[GPA_Baseline]*100' />
      </column>
      <column caption='AI Impact Band' datatype='string' name='[Calculation_2174394257446539266]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_2174394257446178816] &gt; 0.15 THEN &quot;High&quot; &#13;&#10;ELSEIF [Calculation_2174394257446178816] &gt; 0 THEN &quot;Moderate&quot; &#13;&#10;ELSE &quot;None/Negative&quot; END' />
      </column>
      <column caption='Productivity Score' datatype='integer' name='[Calculation_2174394257446690819]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Time_Saved_Hours_Weekly]*[Task_Frequency_Daily]' />
      </column>
      <column caption='Ethics Rank' datatype='integer' name='[Calculation_2174394257446862852]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [AI_Ethics_Concern] = &quot;Low&quot; THEN 1 ELSEIF [AI_Ethics_Concern] = &quot;Medium&quot; THEN 2&#13;&#10;ELSE 3 END' />
      </column>
      <column caption='Total Students' datatype='integer' name='[Calculation_2174394257448808453]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Student_ID])' />
      </column>
